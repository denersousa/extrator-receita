generator client {
  provider = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["receita"]
}

model Empresa {
  id                       Int               @id @default(autoincrement())
  cnpjBase                 String            @unique
  razaoSocial              String?
  naturezaJuridica         String?
  qualificacaoResponsavel  String?
  capitalSocial            Decimal?
  porte                    String?
  enteFederativo           String?

  estabelecimentos         Estabelecimento[]
  @@index([razaoSocial])
  @@index([naturezaJuridica])
  @@map("empresa")
  @@schema("receita")
}

model Estabelecimento {
  id                    Int       @id @default(autoincrement())

  cnpjBase              String
  cnpjOrdem             String
  cnpjDv                String
  cnpjCompleto          String    @unique

  matrizFilial          String
  nomeFantasia          String?

  situacaoCadastral     String
  dataSituacao          String?
  motivoSituacao        String?

  nomeCidadeExterior    String?
  pais                  String?

  dataInicioAtividade   String?

  cnaePrincipal         String
  cnaeSecundarios       String?

  tipoLogradouro        String?
  logradouro            String?
  numero                String?
  complemento           String?
  bairro                String?
  cep                   String?
  uf                    String?
  municipio             String?

  ddd1                  String?
  telefone1             String?
  ddd2                  String?
  telefone2             String?

  dddFax                String?
  fax                   String?

  email                 String?

  situacaoEspecial      String?
  dataSituacaoEspecial  String?
  hashRegistro          String?
  dataAtualizacaoReceita DateTime?

  empresa               Empresa   @relation(fields: [cnpjBase], references: [cnpjBase], onDelete: Restrict, onUpdate: Cascade)

  @@index([cnpjBase])
  @@index([cnaePrincipal])
  @@index([uf])
  @@index([municipio])
  @@map("estabelecimento")
  @@schema("receita")
}

model ImportJob {
  id             BigInt       @id @default(autoincrement())
  status         ImportStatus @default(RUNNING)
  startedAt      DateTime     @default(now())
  endedAt        DateTime?
  totalProcessed BigInt       @default(0)
  totalInserted  BigInt       @default(0)
  totalSkipped   BigInt       @default(0)
  observacao     String?
  files          ImportFile[]
  errors         ImportError[]

  @@map("import_job")
  @@schema("receita")
}

model ImportFile {
  id         BigInt       @id @default(autoincrement())
  importJobId BigInt
  phase      String
  fileName   String
  filePath   String?
  startedAt  DateTime     @default(now())
  endedAt    DateTime?
  processed  BigInt       @default(0)
  inserted   BigInt       @default(0)
  skipped    BigInt       @default(0)
  status     ImportStatus @default(RUNNING)
  importJob  ImportJob    @relation(fields: [importJobId], references: [id], onDelete: Cascade)
  errors     ImportError[]

  @@map("import_file")
  @@schema("receita")
}

model ImportError {
  id           BigInt     @id @default(autoincrement())
  importJobId  BigInt
  importFileId BigInt?
  phase        String?
  lineNumber   BigInt?
  errorCode    String?
  message      String
  payload      Json?
  createdAt    DateTime   @default(now())
  importJob    ImportJob  @relation(fields: [importJobId], references: [id], onDelete: Cascade)
  importFile   ImportFile? @relation(fields: [importFileId], references: [id], onDelete: Cascade)

  @@map("import_error")
  @@schema("receita")
}

enum ImportStatus {
  RUNNING
  SUCCESS
  FAILED
}
